# =============================================================================
# SeismicSage — Root .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/
.venv_local/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.dmypy.json

# ---------------------------------------------------------------------------
# Plate boundary data (downloaded at runtime, not committed)
# ---------------------------------------------------------------------------
backend/data/

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Node / Frontend (for when frontend is added)
# ---------------------------------------------------------------------------
node_modules/
.next/
dist/
.nuxt/
