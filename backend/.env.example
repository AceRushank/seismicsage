# SeismicSage Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Google Gemini API key — get one free at https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------

# The URL of your deployed Vercel frontend (for CORS allow-list).
# Use http://localhost:3000 for local development.
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional — override defaults
# ---------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# How long USGS feed responses are cached in seconds (default: 60).
# USGS updates their feeds every 1-5 minutes; don't set below 30.
USGS_CACHE_TTL_SECONDS=60

# How long Gemini analyses are cached in seconds (default: 3600 = 1 hour).
# The same earthquake event won't regenerate analysis within this window.
GEMINI_CACHE_TTL_SECONDS=3600

# Hard timeout for Gemini API calls in seconds (default: 10).
# Requests exceeding this return a structured fallback response.
GEMINI_TIMEOUT_SECONDS=10
